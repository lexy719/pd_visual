# =============================================================================
# web-design-agent environment config  —  TEMPLATE
# Copy this file to ".env" (same folder) and fill in the keys.
#   Windows:  copy env.example .env
#   Git Bash: cp env.example .env
# The app loads ONLY web-design-agent/.env (not the outer teste/.env, not jarvis).
# Real shell env vars, if set, win over these.
# =============================================================================


# --- IMAGES (optional) -------------------------------------------------------
# Photo source for photo-permitted briefs. Leave unset to use keyless Flux
# (Pollinations) generation, which is the default. A valid Unsplash Access Key
# (https://unsplash.com/oauth/applications) upgrades photo briefs to real stock.
# UNSPLASH_ACCESS_KEY=your-valid-unsplash-access-key


# --- MULTI-MODEL ROUTING (what generation actually uses) ---------------------
# Two independent tiers. Each reads ONLY its own three vars — swap freely.
#   REASONING → questions · concept · plan() · artDirect()   (quality-sensitive)
#   BULK      → per-section scratch codegen · self-critique   (volume)
#   Escalation: a section that fails its import/parse check is retried on REASONING.
#
# The client auto-detects the API dialect from the base URL:
#   *.anthropic.com  → Anthropic Messages API (x-api-key, /messages, content[])
#   anything else    → OpenAI-compatible /chat/completions (Groq, Cerebras, Ollama…)
#
# Anthropic keys start with "sk-ant-". The SAME key works for both tiers.
REASONING_LLM_BASE_URL=https://api.anthropic.com/v1
REASONING_LLM_MODEL=claude-sonnet-5
REASONING_LLM_API_KEY=sk-ant-PASTE-YOUR-KEY-HERE

BULK_LLM_BASE_URL=https://api.anthropic.com/v1
BULK_LLM_MODEL=claude-haiku-4-5-20251001
BULK_LLM_API_KEY=sk-ant-PASTE-YOUR-KEY-HERE


# --- DESIGN tier (legacy / fallback) -----------------------------------------
# Preserved OpenAI-compatible tier. Not on the reasoning/bulk hot path anymore,
# but kept working and swappable. Uncomment ONE block.

# Cerebras
DESIGN_LLM_BASE_URL=https://api.cerebras.ai/v1
DESIGN_LLM_API_KEY=csk-PASTE-YOUR-CEREBRAS-KEY-HERE
DESIGN_LLM_MODEL=gpt-oss-120b

# Groq
# DESIGN_LLM_BASE_URL=https://api.groq.com/openai/v1
# DESIGN_LLM_API_KEY=gsk_PASTE-YOUR-GROQ-KEY-HERE
# DESIGN_LLM_MODEL=llama-3.3-70b-versatile

# Local Ollama — comment out ALL DESIGN_LLM_* above; client defaults to qwen2.5:7b
